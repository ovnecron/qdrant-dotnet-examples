@Api_HostAddress = http://localhost:5010
@IngestCollection = knowledge_chunks_ingest
@AnomalyCollection = anomaly_vectors
@IngestJobId = replace-me

GET {{Api_HostAddress}}/health
Accept: application/json

###

GET {{Api_HostAddress}}/ready
Accept: application/json

###

GET {{Api_HostAddress}}/swagger/v1/swagger.json
Accept: application/json

###

POST {{Api_HostAddress}}/api/v1/admin/collections/init
Content-Type: application/json

{
  "collectionName": "knowledge_chunks",
  "vectorSize": 3,
  "distance": "Cosine"
}

###

POST {{Api_HostAddress}}/api/v1/vectors/upsert
Content-Type: application/json

{
  "collection": "knowledge_chunks",
  "points": [
    {
      "id": "doc-1:0",
      "vector": [0.12, -0.09, 0.31],
      "payload": {
        "docId": "doc-1",
        "source": "docs/intro.md",
        "title": "Introduction",
        "tags": ["intro", "getting-started"],
        "content": "Run AppHost and wait until resources are healthy."
      }
    }
  ]
}

###

POST {{Api_HostAddress}}/api/v1/vectors/search
Content-Type: application/json

{
  "collection": "knowledge_chunks",
  "queryVector": [0.11, -0.05, 0.27],
  "topK": 5,
  "minScore": 0.2,
  "filter": {
    "tagsAny": ["getting-started"],
    "sourceEquals": "docs/intro.md"
  }
}

###

GET {{Api_HostAddress}}/api/v1/vectors/knowledge_chunks/doc-1:0
Accept: application/json

###

DELETE {{Api_HostAddress}}/api/v1/vectors
Content-Type: application/json

{
  "collection": "knowledge_chunks",
  "chunkIds": ["doc-1:0", "doc-1:1"]
}

###

POST {{Api_HostAddress}}/api/v1/admin/collections/init
Content-Type: application/json

{
  "collectionName": "{{IngestCollection}}",
  "vectorSize": 384,
  "distance": "Cosine"
}

###

POST {{Api_HostAddress}}/api/v1/ingest/markdown
Content-Type: application/json

{
  "collection": "{{IngestCollection}}",
  "docId": "guide-local-run",
  "sourceId": "docs/local-run.md",
  "title": "Local Run",
  "markdown": "# Local Run\n\nRun AppHost and wait until resources are healthy.",
  "tags": ["tutorial", "local"],
  "tenantId": "tenant-a"
}

###

GET {{Api_HostAddress}}/api/v1/ingest/jobs/{{IngestJobId}}
Accept: application/json

###

POST {{Api_HostAddress}}/api/v1/search/query
Content-Type: application/json

{
  "collection": "{{IngestCollection}}",
  "queryText": "How do I run this locally?",
  "topK": 3,
  "filter": {
    "tenantIdEquals": "tenant-a"
  }
}

###

POST {{Api_HostAddress}}/api/v1/rag/query
Content-Type: application/json

{
  "collection": "{{IngestCollection}}",
  "question": "How do I check health and ready endpoints locally?",
  "topK": 3,
  "includeDebug": true,
  "filter": {
    "tenantIdEquals": "tenant-a",
    "tagsAny": ["local"]
  }
}

###

POST {{Api_HostAddress}}/api/v1/admin/collections/init
Content-Type: application/json

{
  "collectionName": "{{AnomalyCollection}}",
  "vectorSize": 3,
  "distance": "Cosine"
}

###

POST {{Api_HostAddress}}/api/v1/vectors/upsert
Content-Type: application/json

{
  "collection": "{{AnomalyCollection}}",
  "points": [
    {
      "id": "baseline-1",
      "vector": [1.0, 0.0, 0.0],
      "payload": {
        "docId": "acct-42",
        "source": "fixtures/anomaly-baseline.json",
        "tags": ["baseline", "normal"],
        "content": "Baseline anomaly reference point.",
        "tenantId": "tenant-a"
      }
    },
    {
      "id": "baseline-2",
      "vector": [0.99, 0.01, 0.0],
      "payload": {
        "docId": "acct-42",
        "source": "fixtures/anomaly-baseline.json",
        "tags": ["baseline", "normal"],
        "content": "Baseline anomaly reference point.",
        "tenantId": "tenant-a"
      }
    },
    {
      "id": "baseline-3",
      "vector": [0.97, 0.03, 0.0],
      "payload": {
        "docId": "acct-42",
        "source": "fixtures/anomaly-baseline.json",
        "tags": ["baseline", "normal"],
        "content": "Baseline anomaly reference point.",
        "tenantId": "tenant-a"
      }
    }
  ]
}

###

POST {{Api_HostAddress}}/api/v1/anomaly/score
Content-Type: application/json

{
  "collection": "{{AnomalyCollection}}",
  "vector": [0.98, 0.02, 0.0],
  "topK": 3,
  "threshold": 0.35,
  "filter": {
    "tenantIdEquals": "tenant-a"
  }
}

###

POST {{Api_HostAddress}}/api/v1/anomaly/text/score
Content-Type: application/json

{
  "collection": "{{IngestCollection}}",
  "text": "Check the /health and /ready endpoints after startup.",
  "topK": 1,
  "threshold": 0.35,
  "includeDebug": true,
  "filter": {
    "tenantIdEquals": "tenant-a"
  }
}

###
