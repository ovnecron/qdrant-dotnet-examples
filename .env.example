ASPNETCORE_ENVIRONMENT=Development

# Optional overrides for local runs.
QDRANT__ENDPOINT_REST=http://localhost:6333
QDRANT__ENDPOINT_GRPC=http://localhost:6334
QDRANT__APIKEY=
QDRANT__COLLECTION=knowledge_chunks
EMBEDDING__PROVIDER=Deterministic
EMBEDDING__MODEL=hashing-text-v1
EMBEDDING__DIMENSION=384
EMBEDDING__BATCHSIZE=16
EMBEDDING__SCHEMAVERSION=v1

# Optional override for AppHost and integration tests.
# Format: repository:tag
QDRANT_CONTAINER_IMAGE=qdrant/qdrant:v1.17.0
